

{% liquid
  assign product = closest.product
-%}

{% liquid
  # Check if any child block has collection grid style enabled
  assign enable_collection_grid_style = false
  for child_block in block.blocks
    if child_block.type == '_product-card-gallery' and child_block.settings.enable_collection_grid_style
      assign enable_collection_grid_style = true
      break
    endif
  endfor
%}

{% capture children %}
  {% content_for 'blocks', closest.product: product %}
{% endcapture %}

{% if enable_collection_grid_style %}
  {% liquid
    assign show_rating = block.settings.show_rating | default: true
    assign show_cta_button = block.settings.show_cta_button | default: true
  %}

  {% capture additional_content %}
    {% if show_rating or show_cta_button %}
      <div class="product-card__grid-info">
        {%- comment -%} Star Rating {%- endcomment -%}
        {% if show_rating %}
          <div class="product-card__rating">
            <span class="rating-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span class="rating-value">({{ block.settings.default_rating }})</span>
          </div>
        {% endif %}

        {%- comment -%} CTA Button {%- endcomment -%}
        {% if show_cta_button %}
          <a
            href="{{ product.selected_or_first_available_variant.url | default: '#' }}"
            class="product-card__grid-button"
          >
            <svg class="button-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
            <span>{{ block.settings.button_label }}</span>
          </a>
        {% endif %}
      </div>
    {% endif %}
  {% endcapture %}

  {% render 'product-card', children: children, product: product, additional_content: additional_content %}
{% else %}
  {% render 'product-card', children: children, product: product %}
{% endif %}

{% schema %}
{
  "name": "t:names.product_card",
  "blocks": [
    {
      "type": "_product-card-group"
    },
    {
      "type": "text"
    },
    {
      "type": "image"
    },
    {
      "type": "buy-buttons"
    },
    {
      "type": "price"
    },
    {
      "type": "review"
    },
    {
      "type": "sku"
    },
    {
      "type": "swatches"
    },
    {
      "type": "_product-card-gallery"
    },
    {
      "type": "product-title"
    },
    {
      "type": "custom-liquid"
    },
    {
      "type": "@app"
    }
  ],
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_card"
    },
    {
      "type": "range",
      "id": "product_card_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Collection Grid Style"
    },
    {
      "type": "paragraph",
      "content": "These settings appear when collection grid style is enabled in the Product Image block"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View Product"
    },
    {
      "type": "text",
      "id": "default_rating",
      "label": "Default rating",
      "default": "4.7",
      "info": "Default star rating value"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cta_button",
      "label": "Show CTA button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
