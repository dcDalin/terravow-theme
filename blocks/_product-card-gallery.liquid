

{% assign product = closest.product %}
{% assign block_settings = block.settings %}

{% liquid
  assign enable_collection_grid_style = block_settings.enable_collection_grid_style | default: false

  assign media_count = product.media.size
  if media_count > 5
    assign media_count = 5
  endif
%}

{% capture children %}
  {% unless product == blank %}
    <div
      class="product-badges product-badges--{{ settings.badge_position }}"
      style="
        --badge-border-radius: {{ settings.badge_corner_radius }}px;
        --badge-font-family: var(--font-{{ settings.badge_font_family }}--family); --badge-font-weight: var(--font-{{ settings.badge_font_family }}--weight); --badge-text-transform: {{ settings.badge_text_transform }};
      "
    >
      {%- if product.available == false or product.compare_at_price > product.price -%}
        <div
          class="
            product-badges__badge product-badges__badge--rectangle
            {% if product.available == false %} color-{{ settings.badge_sold_out_color_scheme }}{% elsif product.compare_at_price > product.price %} color-{{ settings.badge_sale_color_scheme }}{% endif %}
          "
        >
          {%- if product.available == false -%}
            {{ 'content.product_badge_sold_out' | t }}
          {%- elsif product.compare_at_price > product.price -%}
            {{ 'content.product_badge_sale' | t }}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
    {%- comment -%} Hide quick-add when collection grid style is enabled {%- endcomment -%}
    {% unless enable_collection_grid_style %}
      {%  if settings.quick_add or settings.mobile_quick_add %}
        {% render 'quick-add', product: product, section_id: section.id %}
      {% endif %}
    {% endunless %}

    {%- comment -%} Carousel Dots for Collection Grid Style {%- endcomment -%}
    {% if enable_collection_grid_style and media_count > 1 %}
      <div class="product-card-gallery-carousel-dots" data-product-card-gallery-carousel-dots data-enable-hover="true">
        {% for i in (1..media_count) %}
          <button
            class="product-card-gallery-carousel-dot {% if forloop.first %}active{% endif %}"
            data-slide="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  {% endunless %}
{% endcapture %}

{% render 'card-gallery', children: children, enable_collection_grid_style: enable_collection_grid_style %}

{% # Title and price for the zoomed out grid view %}
<div class="product-grid-view-zoom-out--details">
  {% if product == blank %}
    <h3 class="h4">{{ 'content.product_card_placeholder' | t }}</h3>
  {% else %}
    <h3 class="h4">{{ product.title }}</h3>
  {% endif %}
</div>

{% stylesheet %}
  .product-badges {
    --badge-inset: max(var(--padding-xs), calc((var(--border-radius) + var(--padding-xs)) * (1 - cos(45deg))));

    position: absolute;
    z-index: var(--layer-flat);
  }

  .product-badges--bottom-left {
    bottom: calc(var(--badge-inset) + var(--padding-block-start));
    left: calc(var(--badge-inset) + var(--padding-inline-start));
  }

  .product-badges--top-left {
    top: calc(var(--badge-inset) + var(--padding-block-start));
    left: calc(var(--badge-inset) + var(--padding-inline-start));
  }

  .product-badges--top-right {
    top: calc(var(--badge-inset) + var(--padding-block-start));
    right: calc(var(--badge-inset) + var(--padding-inline-start));
  }

  .product-badges__badge {
    --badge-font-size: var(--font-size--xs);

    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--color-foreground);
    background: var(--color-background);
    font-size: var(--badge-font-size);
    font-family: var(--badge-font-family);
    font-weight: var(--badge-font-weight);
    text-transform: var(--badge-text-transform);
    border-radius: var(--badge-border-radius);
  }

  .product-badges__badge--rectangle {
    padding-block: var(--badge-rectangle-padding-block);
    padding-inline: var(--badge-rectangle-padding-inline);
  }

  /* Carousel Dots for Collection Grid Style */
  .product-card-gallery-carousel-dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
    pointer-events: auto;
  }

  .product-card-gallery-carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.6);
    border: none;
    cursor: pointer;
    transition: all 0.2s;
    padding: 0;
  }

  .product-card-gallery-carousel-dot:hover {
    background: rgba(255, 255, 255, 0.9);
    transform: scale(1.2);
  }

  .product-card-gallery-carousel-dot.active {
    background: white;
    width: 24px;
    border-radius: 4px;
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function() {
    const carouselDotContainers = document.querySelectorAll('[data-product-card-gallery-carousel-dots]');

    carouselDotContainers.forEach(dotsContainer => {
      const cardGallery = dotsContainer.closest('.card-gallery');
      if (!cardGallery) return;

      const slideshowComponent = cardGallery.querySelector('slideshow-component');
      if (!slideshowComponent) return;

      const slides = slideshowComponent.querySelectorAll('slideshow-slide:not([hidden])');
      const dots = dotsContainer.querySelectorAll('.product-card-gallery-carousel-dot');
      const enableHover = dotsContainer.getAttribute('data-enable-hover') === 'true';

      if (slides.length <= 1) return;

      let currentSlide = 0;
      let autoplayInterval = null;

      function goToSlide(index) {
        if (dots[currentSlide]) {
          dots[currentSlide].classList.remove('active');
        }

        currentSlide = index;

        // Use the slideshow component's navigation method if available
        if (slideshowComponent && slideshowComponent.select) {
          slideshowComponent.select(index);
        }

        if (dots[currentSlide]) {
          dots[currentSlide].classList.add('active');
        }
      }

      // Handle dot clicks
      dots.forEach((dot, index) => {
        dot.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          goToSlide(index);
        });
      });

      // Handle hover auto-play
      if (enableHover) {
        cardGallery.addEventListener('mouseenter', () => {
          autoplayInterval = setInterval(() => {
            const nextSlide = (currentSlide + 1) % slides.length;
            goToSlide(nextSlide);
          }, 2000);
        });

        cardGallery.addEventListener('mouseleave', () => {
          if (autoplayInterval) {
            clearInterval(autoplayInterval);
            autoplayInterval = null;
          }
        });
      }
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:names.product_image",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_media"
    },
    {
      "type": "checkbox",
      "id": "enable_collection_grid_style",
      "label": "Enable collection grid style",
      "default": false,
      "info": "Shows carousel dots on hover. Hides quick-add button and arrow controls."
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "portrait",
      "label": "t:settings.aspect_ratio",
      "info": "t:info.aspect_ratio_adjusted"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_card_media",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
