{% doc %}
  Renders an information marquee with clickable items that reveal details.

  @example
  {% content_for 'block', type: 'information-marquee', id: 'info-marquee' %}
{% enddoc %}

<div
  class="information-marquee"
  data-marquee-speed="{{ block.settings.marquee_speed }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank %}
    <h3 class="information-marquee__title">{{ block.settings.title }}</h3>
  {% endif %}

  <div class="information-marquee__container">
    <div class="information-marquee__track" data-marquee-track>
      {% for i in (1..3) %}
        <div class="information-marquee__content">
          {% for item in (1..5) %}
            {% liquid
              assign item_title_key = 'item_' | append: item | append: '_title'
              assign item_subtitle_key = 'item_' | append: item | append: '_subtitle'
              assign item_body_key = 'item_' | append: item | append: '_body'

              assign item_title = block.settings[item_title_key]
              assign item_subtitle = block.settings[item_subtitle_key]
              assign item_body = block.settings[item_body_key]
            %}

            {% if item_title != blank %}
              <button
                type="button"
                class="information-marquee__item"
                data-item-index="{{ item }}"
                aria-expanded="false"
                aria-controls="marquee-card-{{ block.id }}-{{ item }}"
              >
                {{ item_title }}
              </button>
            {% endif %}
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="information-marquee__cards">
    {% for item in (1..5) %}
      {% liquid
        assign item_title_key = 'item_' | append: item | append: '_title'
        assign item_subtitle_key = 'item_' | append: item | append: '_subtitle'
        assign item_body_key = 'item_' | append: item | append: '_body'

        assign item_title = block.settings[item_title_key]
        assign item_subtitle = block.settings[item_subtitle_key]
        assign item_body = block.settings[item_body_key]
      %}

      {% if item_title != blank %}
        <div
          id="marquee-card-{{ block.id }}-{{ item }}"
          class="information-marquee__card"
          data-card-index="{{ item }}"
          hidden
        >
          {% if item_subtitle != blank %}
            <h4 class="information-marquee__card-subtitle">{{ item_subtitle }}</h4>
          {% endif %}
          {% if item_body != blank %}
            <div class="information-marquee__card-body">{{ item_body }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .information-marquee {
    width: 100%;
    overflow: hidden;
  }

  .information-marquee__title {
    text-align: center;
    margin-block-end: var(--gap-lg);
  }

  .information-marquee__container {
    position: relative;
    overflow: hidden;
    width: 100%;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .information-marquee__track {
    display: flex;
    gap: var(--gap-md);
    width: fit-content;
    animation: marquee-scroll var(--marquee-speed, 20s) linear infinite;
  }

  .information-marquee__track[data-paused='true'] {
    animation-play-state: paused !important;
  }

  .information-marquee__content {
    display: flex;
    gap: var(--gap-md);
    flex-shrink: 0;
  }

  .information-marquee__item {
    padding: var(--padding-md) var(--padding-lg);
    background-color: var(--color-background);
    border: var(--style-border-width) solid var(--color-border);
    border-radius: var(--style-border-radius-buttons-primary);
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--animation-speed) var(--animation-easing);
    font-family: inherit;
    font-size: var(--font-size--md);
    color: var(--color-foreground);
  }

  .information-marquee__item:hover {
    background-color: var(--color-foreground);
    color: var(--color-background);
    transform: translateY(-2px);
  }

  .information-marquee__item[aria-expanded='true'] {
    background-color: var(--color-primary-button-background);
    color: var(--color-primary-button-text);
    border-color: var(--color-primary-button-background);
  }

  .information-marquee__cards {
    margin-block-start: var(--gap-lg);
  }

  .information-marquee__card {
    padding: var(--padding-xl);
    background-color: var(--color-background);
    border: var(--style-border-width) solid var(--color-border);
    border-radius: var(--style-border-radius-lg);
    animation: slide-down 0.3s var(--animation-easing);
  }

  .information-marquee__card[hidden] {
    display: none;
  }

  .information-marquee__card-subtitle {
    margin-block-end: var(--gap-md);
    font-size: var(--font-size--lg);
    font-weight: 600;
  }

  .information-marquee__card-body {
    line-height: 1.6;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-100% / 3));
    }
  }

  @keyframes slide-down {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}

{% javascript %}
  class InformationMarquee {
    constructor(element) {
      this.marquee = element;
      this.track = this.marquee.querySelector('[data-marquee-track]');
      this.items = this.marquee.querySelectorAll('.information-marquee__item');
      this.cards = this.marquee.querySelectorAll('.information-marquee__card');
      this.currentActiveItem = null;

      this.init();
    }

    init() {
      this.items.forEach(item => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          this.handleItemClick(e.currentTarget);
        });
      });

      // Resume marquee when clicking outside
      document.addEventListener('click', (e) => {
        if (!this.marquee.contains(e.target)) {
          this.closeAll();
        }
      });
    }

    handleItemClick(item) {
      const itemIndex = item.dataset.itemIndex;
      const targetCard = this.marquee.querySelector(`[data-card-index="${itemIndex}"]`);

      if (!targetCard) return;

      // Pause the marquee
      this.track.setAttribute('data-paused', 'true');

      // If clicking the same item, close it
      if (this.currentActiveItem === item) {
        this.closeAll();
        return;
      }

      // Close all other items
      this.items.forEach(i => i.setAttribute('aria-expanded', 'false'));
      this.cards.forEach(c => c.hidden = true);

      // Open the clicked item
      item.setAttribute('aria-expanded', 'true');
      targetCard.hidden = false;
      this.currentActiveItem = item;
    }

    closeAll() {
      this.items.forEach(i => i.setAttribute('aria-expanded', 'false'));
      this.cards.forEach(c => c.hidden = true);
      this.track.setAttribute('data-paused', 'false');
      this.currentActiveItem = null;
    }
  }

  // Initialize all marquees on the page
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.information-marquee').forEach(marquee => {
      new InformationMarquee(marquee);
    });
  });

  // Also initialize if DOM is already loaded (for dynamic content)
  if (document.readyState === 'interactive' || document.readyState === 'complete') {
    document.querySelectorAll('.information-marquee').forEach(marquee => {
      if (!marquee.hasAttribute('data-marquee-initialized')) {
        marquee.setAttribute('data-marquee-initialized', 'true');
        new InformationMarquee(marquee);
      }
    });
  }
{% endjavascript %}

